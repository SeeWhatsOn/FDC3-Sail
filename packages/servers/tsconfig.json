{
  "extends": "../../tsconfig.root.json",
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM"
    ],
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "typescript-plugin-css-modules"
      }
    ],
    "outDir": "./dist",
    "rootDirs": [
      "socket/src"
    ],
  },
  "include": [
    "socket/src/**/*.tsx",
    "socket/src/**/*.ts",
    "types.d.ts",
    "socket/src/**/*.css"
  ],
  "references": [
    {
      "path": "../common"
    }
  ]
}