{
  "extends": "../../tsconfig.root.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "plugins": [
      {
        "name": "typescript-plugin-css-modules"
      }
    ],
    "outDir": "./dist",
    "rootDirs": ["./src"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.tsx", "src/**/*.ts", "types.d.ts", "src/**/*.css"],
  "references": [
    {
      "path": "../common"
    }
  ]
}
