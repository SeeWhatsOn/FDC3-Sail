{
  "name": "@finos/fdc3-sail-shared",
  "version": "0.0.0",
  "type": "module",
  "description": "Shared constants and message types for FDC3-Sail inter-package communication",
  "scripts": {
    "clean": "npx rimraf dist",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "electron": "^37.2.6",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "@finos/fdc3": "^2.2.0",
    "@finos/fdc3-agent-proxy": "^2.2.1-beta.3",
    "@finos/fdc3-schema": "^2.2.1-beta.3",
    "@finos/fdc3-web-impl": "^2.2.1-beta.3",
    "typescript": "^5.7.3"
  }
}
