{
  "name": "@finos/fdc3-sail-desktop-agent",
  "version": "0.0.1",
  "type": "module",
  "description": "FDC3 Desktop Agent implementation for Sail",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./browser": {
      "import": "./dist/src/browser/index.js",
      "types": "./dist/src/browser/index.d.ts"
    },
    "./transports": {
      "import": "./dist/src/transports/index.js",
      "types": "./dist/src/transports/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "generate:schemas": "tsx scripts/generate-schemas.ts"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^24.2.1",
    "@vitest/ui": "^3.2.4",
    "json-refs": "^3.0.15",
    "json-schema-to-zod": "^2.6.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.3.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@finos/fdc3": "^2.2.0",
    "@finos/fdc3-agent-proxy": "^2.2.1-beta.3",
    "@finos/fdc3-schema": "^2.2.1-beta.3",
    "@finos/fdc3-web-impl": "^2.2.1-beta.3",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^4.1.11"
  },
  "author": "",
  "license": "ISC"
}
