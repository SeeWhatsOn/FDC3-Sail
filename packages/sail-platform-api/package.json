{
  "name": "@finos/sail-platform-api",
  "version": "0.0.1",
  "type": "module",
  "description": "SDK for the FDC3 Sail platform - wraps sail-desktop-agent with Sail middleware and transports",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "unused:check": "knip",
    "validate": "npm run typecheck && npm run lint && npm run format"
  },
  "devDependencies": {},
  "dependencies": {
    "@finos/fdc3": "^2.2.0",
    "@finos/sail-desktop-agent": "workspace:*",
    "zod": "^4.1.11"
  }
}