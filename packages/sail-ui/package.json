{
  "name": "@finos/sail-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/sail-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/sail-ui.js"
    },
    "./styles": {
      "import": "./dist/sail-ui.css",
      "require": "./dist/sail-ui.css"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./sidebar": {
      "types": "./dist/components/ui/sidebar.d.ts",
      "import": "./dist/components/ui/sidebar.js"
    },
    "./button": {
      "types": "./dist/components/ui/button.d.ts",
      "import": "./dist/components/ui/button.js"
    },
    "./logo": {
      "types": "./dist/components/ui/logo.d.ts",
      "import": "./dist/components/ui/logo.js"
    }
  },
  "sideEffects": [
    "./src/index.css",
    "./dist/sail-ui.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --check .",
    "preview": "vite preview",
    "typecheck": "tsc",
    "validate": "npm run typecheck && npm run lint && npm run format"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.7"
  },
  "devDependencies": {}
}