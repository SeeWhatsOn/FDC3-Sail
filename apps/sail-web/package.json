{
  "name": "@finos/sail-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "format:fix": "prettier --write .",
    "format": "prettier --check .",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:run": "vitest run",
    "test": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "unused:check": "knip",
    "validate": "npm run typecheck && npm run lint && npm run format"
  },
  "dependencies": {
    "@finos/fdc3": "^2.2.0",
    "@finos/sail-platform-api": "workspace:*",
    "@finos/sail-ui": "workspace:*",
    "@tailwindcss/vite": "^4.1.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dockview": "^4.7.1",
    "dockview-react": "^4.7.0",
    "immer": "^10.1.3",
    "lucide-react": "^0.542.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.3.7",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "dockview-react": "^4.7.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "sail-ui": "*",
    "tailwindcss": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^26.1.0"
  }
}