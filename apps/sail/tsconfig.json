{
  "_comment": "TODO: Remove test files from the 'exclude' array below and fix the Vitest/Jest type conflicts.",
  "extends": "../../tsconfig.root.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "moduleDetection": "force",
    "paths": {
      "@/*": ["../../packages/sail-ui/src/*"],
      "sail-ui": ["../../packages/sail-ui/src/index.ts"],
      "sail-ui/*": ["../../packages/sail-ui/src/*"]
    },
    "outDir": "./dist",
    "types": ["vitest/globals"],
    "noEmit": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "vitest.config.ts"]
}
