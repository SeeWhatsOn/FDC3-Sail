{
  "name": "@finos/fdc3-sail-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/sail-app.umd.cjs",
  "module": "./dist/sail-app.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/sail-app.js",
      "require": "./dist/sail-app.umd.cjs"
    },
    "./style.css": {
      "development": "./src/index.css",
      "default": "./dist/sail-app.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:lib": "vite build --mode lib --watch",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --mode lib",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@finos/fdc3": "^2.2.0",
    "@finos/fdc3-agent-proxy": "^2.2.1-beta.3",
    "@finos/fdc3-schema": "^2.2.1-beta.3",
    "@finos/fdc3-web-impl": "^2.2.1-beta.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@tailwindcss/vite": "^4.1.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dockview-react": "^4.7.0",
    "immer": "^10.1.3",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sail-ui": "*",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.7",
    "zustand": "^5.0.8"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": "^4.0.0",
    "dockview-react": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "zustand": "^5.0.0",
    "sail-ui": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  }
}
