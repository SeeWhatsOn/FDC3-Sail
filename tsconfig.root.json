{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,

    "lib": ["ES2023", "DOM"],
    "target": "ESNext",
    "composite": true,
    "incremental": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,

    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true
  }
}
