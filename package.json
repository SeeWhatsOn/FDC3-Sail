{
  "name": "@finos/fdc3-sail",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "npm run clean --workspaces",
    "build": "npm run build --workspaces --if-present",
    "dev:web": "concurrently \"npm run dev --workspace=@finos/sail-desktop-agent\" \"npm run build:watch --workspace=@finos/sail-platform-api\" \"npm run dev --workspace=@finos/fdc3-sail-server\" \"npm run dev --workspace=@finos/fdc3-sail-web\"",
    "dev:desktop": "concurrently \"npm run dev --workspace=@finos/fdc3-sail-server\" \"npm run dev --workspace=@finos/fdc3-sail-electron\" \"npm run dev --workspace=apps/example-fdc3-apps\"",
    "docs:dev": "npm run start --workspace=@finos/fdc3-sail-docs",
    "docs:build": "npm run build --workspace=@finos/fdc3-sail-docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "validate": "npm run typecheck && npm run lint && npm run build"
  },
  "workspaces": [
    "packages/sail-desktop-agent",
    "packages/sail-ui",
    "packages/sail-platform-api",
    "apps/sail-web",
    "apps/sail-electron",
    "apps/sail-server",
    "website"
  ],
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.33.0",
    "@eslint/json": "^0.13.1",
    "@types/node": "^25.x.x",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.x",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^16.3.0",
    "knip": "^5.82.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.x",
    "vitest": "^4.0.18",
    "@vitest/ui": "^4.0.18"
  }
}