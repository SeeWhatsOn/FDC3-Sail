{
  "name": "@finos/fdc3-sail",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "npm run clean --workspaces",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "web": "npm run build && npm run web --workspaces --if-present",
    "example-apps": "npm run dev --workspace=apps/example-apps",
    "electron": "concurrently \"npm run web\" \"npm run electron --workspaces --if-present \"",
    "start:all": "concurrently \"npm run web\" \"npm run example-apps\" \"npm run electron\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --build --verbose",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check-all": "npm run lint && npm run type-check && npm run format"
  },
  "workspaces": [
    "packages/shared",
    "packages/preload",
    "packages/socket",
    "packages/app-directories",
    "apps/sail-web",
    "apps/sail-desktop",
    "apps/example-apps"
  ],
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.33.0",
    "@eslint/json": "^0.13.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.39.1"
  },
  "dependencies": {
    "wait-on": "^8.0.3"
  }
}
