{
  "name": "@finos/fdc3-sail",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "npm run clean --workspaces",
    "build": "npm run build --workspaces --if-present",
    "dev:web": "concurrently \"npm run dev --workspace=apps/sail-socket\" \"npm run dev --workspace=apps/sail-web\" \"npm run dev --workspace=apps/example-fdc3-apps\"",
    "dev:desktop": "concurrently \"npm run dev --workspace=apps/sail-socket\" \"npm run dev --workspace=packages/sail-app\" \"npm run dev --workspace=apps/example-fdc3-apps\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "validate": "npm run typecheck && npm run lint && npm run build"
  },
  "workspaces": [
    "packages/desktop-agent",
    "packages/app-directories",
    "packages/sail-app",
    "packages/sail-ui",
    "apps/sail-web",
    "apps/sail-desktop",
    "apps/sail-socket",
    "apps/example-fdc3-apps"
  ],
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.33.0",
    "@eslint/json": "^0.13.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "globals": "^16.3.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.39.1"
  },
  "dependencies": {
    "@finos/fdc3-web-impl": "^2.2.0",
    "wait-on": "^8.0.3"
  }
}
